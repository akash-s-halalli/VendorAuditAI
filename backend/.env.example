# ===========================================
# VendorAuditAI Backend - Environment Config
# ===========================================
# Copy this file to .env and fill in your values

# Application
APP_NAME=VendorAuditAI
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Server
HOST=0.0.0.0
PORT=8000

# Database
# SQLite (default for development - zero setup)
DATABASE_URL=sqlite+aiosqlite:///./vendorauditai.db

# PostgreSQL (for production or when you need vector search)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vendorauditai
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./uploads

# MinIO (optional - for S3-compatible storage)
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=documents
# MINIO_SECURE=false

# AI/ML APIs (required for analysis features)
# -----------------------------------------------
# Provider Selection
# LLM_PROVIDER: Which LLM to use for document analysis and chat
#   - anthropic: Uses Claude models (requires ANTHROPIC_API_KEY)
#   - gemini: Uses Google Gemini models (requires GOOGLE_API_KEY)
LLM_PROVIDER=anthropic

# EMBEDDING_PROVIDER: Which service to use for text embeddings
#   - openai: Uses OpenAI embeddings (requires OPENAI_API_KEY)
#   - gemini: Uses Google Gemini embeddings (requires GOOGLE_API_KEY)
EMBEDDING_PROVIDER=openai

# Anthropic (Claude) Configuration
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI Configuration
OPENAI_API_KEY=sk-your-key-here
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

# Google Gemini Configuration
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Document Processing
# Azure Document Intelligence (optional - uses PyMuPDF as fallback)
# USE_AZURE_DOC_INTEL=false
# AZURE_DOC_INTEL_ENDPOINT=https://xxx.cognitiveservices.azure.com
# AZURE_DOC_INTEL_KEY=xxx

# Security - JWT
JWT_SECRET_KEY=jwt-secret-change-me-generate-secure-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated for multiple origins)
# For production, add your Netlify domain:
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://vendor-audit-ai.netlify.app"]
CORS_ALLOW_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Celery (optional - for async task processing)
# USE_CELERY=false
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1
